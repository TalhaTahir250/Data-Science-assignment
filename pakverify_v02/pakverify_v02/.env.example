# PAK_VERIFY — Environment Configuration
# =============================================
# Copy this file to .env and fill in your keys

# ── REQUIRED ──────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── API SECURITY ──────────────────────────────
# This key goes in X-API-Key header with every request (v0.1 default test client)
API_KEY=pakverify-v01-key

# ── OPTIONAL ──────────────────────────────────
MAX_FILE_MB=10

# ── v0.2: Session storage (per-session temp files, hard-deleted on completion) ──
SESSION_STORAGE_DIR=app/storage/sessions
SESSION_TTL_MINUTES=30

# ── v0.2: Outbound webhook dispatch ──
WEBHOOK_TIMEOUT_SECONDS=5.0
WEBHOOK_MAX_RETRIES=2
